FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC

# Clear any proxy settings that might interfere
ENV http_proxy=""
ENV https_proxy=""
ENV HTTP_PROXY=""
ENV HTTPS_PROXY=""
ENV no_proxy="*"
ENV NO_PROXY="*"

# Clear git proxy settings
RUN git config --global --unset http.proxy || true && \
    git config --global --unset https.proxy || true

# Install newer CMake (3.28) from Kitware APT repo — OR-Tools requires >= 3.24
RUN apt-get update && apt-get install -y ca-certificates gpg wget && \
    wget -O - https://apt.kitware.com/keys/kitware-archive-latest.asc 2>/dev/null | gpg --dearmor - | tee /usr/share/keyrings/kitware-archive-keyring.gpg >/dev/null && \
    echo 'deb [signed-by=/usr/share/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/ubuntu/ jammy main' | tee /etc/apt/sources.list.d/kitware.list >/dev/null && \
    apt-get update && rm -rf /var/lib/apt/lists/*

# Install build dependencies (from orcaslicer/scripts/linux.d/debian)
RUN apt-get update && apt-get install -y \
    autoconf \
    build-essential \
    cmake \
    eglexternalplatform-dev \
    extra-cmake-modules \
    file \
    g++ \
    clang \
    lld \
    gettext \
    git \
    libcurl4-openssl-dev \
    libdbus-1-dev \
    libglew-dev \
    libgstreamer1.0-dev \
    libgstreamer-plugins-base1.0-dev \
    libgtk-3-dev \
    libmspack-dev \
    libsecret-1-dev \
    libspnav-dev \
    libssl-dev \
    libtool \
    libudev-dev \
    libwebkit2gtk-4.0-dev \
    libwebkit2gtk-4.1-dev \
    ninja-build \
    texinfo \
    wget \
    curl \
    libfuse-dev \
    m4 \
    locales \
    gdb \
    libcanberra-gtk3-module \
    libcanberra-gtk-module \
    linux-tools-generic \
    && rm -rf /var/lib/apt/lists/*

# Generate locales
RUN locale-gen en_US.UTF-8 en_GB.UTF-8 && \
    update-locale LANG=en_US.UTF-8

ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

# Set up working directory
WORKDIR /orcaslicer

# Default command
CMD ["/bin/bash"]
